{
  "name": "mis-viajes-crm",
  "version": "0.1.0",
  "private": true,
  "description": "Mis Viajes CRM - es-MX first, en-US optional",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-metrics": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.1"
  },
  "scripts": {
    "dev:api": "tsx src/server.ts",
    "auth:smoke": "node tools/ops/auth-smoke-check.mjs",
    "auth:smoke:token": "AUTH_SMOKE_VERIFY_TOKEN_MODE=true npm run auth:smoke",
    "auth:smoke:en": "AUTH_SMOKE_LOCALE=en-US npm run auth:smoke",
    "auth:smoke:token:en": "AUTH_SMOKE_VERIFY_TOKEN_MODE=true AUTH_SMOKE_LOCALE=en-US npm run auth:smoke",
    "ai:schema:smoke": "node tools/ops/ai-schema-smoke-check.mjs",
    "ai:schema:smoke:token": "AI_SCHEMA_SMOKE_AUTH_MODE=token npm run ai:schema:smoke",
    "ai:schema:smoke:en": "AI_SCHEMA_SMOKE_LOCALE=en-US npm run ai:schema:smoke",
    "ai:schema:smoke:token:en": "AI_SCHEMA_SMOKE_AUTH_MODE=token AI_SCHEMA_SMOKE_LOCALE=en-US npm run ai:schema:smoke",
    "ai:render:smoke": "node tools/ops/ai-render-smoke-check.mjs",
    "ai:render:smoke:token": "AI_RENDER_SMOKE_AUTH_MODE=token npm run ai:render:smoke",
    "ai:render:smoke:en": "AI_RENDER_SMOKE_LOCALE=en-US npm run ai:render:smoke",
    "ai:render:smoke:token:en": "AI_RENDER_SMOKE_AUTH_MODE=token AI_RENDER_SMOKE_LOCALE=en-US npm run ai:render:smoke",
    "smoke:matrix": "node tools/ops/smoke-matrix-check.mjs",
    "smoke:matrix:json": "SMOKE_MATRIX_SUMMARY_FILE=./tmp/smoke-matrix-summary.json npm run smoke:matrix",
    "smoke:matrix:token": "SMOKE_MATRIX_AUTH_MODES=token npm run smoke:matrix",
    "smoke:matrix:en": "SMOKE_MATRIX_LOCALES=en-US npm run smoke:matrix",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "tsx --test src/core/**/*.test.ts src/modules/**/*.test.ts",
    "test:integration": "tsx --test src/integration/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "quality": "npm run quality:file-size && npm run quality:function-size && npm run quality:docs && npm run quality:codeowners",
    "quality:file-size": "node tools/quality/check-max-lines.mjs",
    "quality:function-size": "node tools/quality/check-function-size.mjs",
    "quality:docs": "node tools/quality/check-required-docs.mjs",
    "quality:codeowners": "node tools/quality/check-codeowners.mjs"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
